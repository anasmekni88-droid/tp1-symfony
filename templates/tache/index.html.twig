{% extends 'base.html.twig' %}

{% block title %}Liste des taches{% endblock %}

{% block body %}
    <h1 class="mb-4">📰 Tâches (depuis la BDD)</h1>

    {% if taches is empty %}
        <div class="alert alert-info">
            Aucune tâche en base de données. 
            <a href="{{ path('tache_add') }}" class="alert-link">Créer une tâche</a>
        </div>
    {% else %}
        <div class="table-responsive">
            <table class="table table-bordered table-hover mt-4">
                <thead class="table-dark text-center">
                    <tr>
                        <th>ID</th>
                        <th>Titre</th>
                        <th>Date de création</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    {% for tache in taches %}
                        <tr>
                            <td class="text-center">{{ tache.id }}</td>
                            <td>{{ tache.titre }}</td>
                            <td>{{ tache.dateCreation|date('d/m/Y') }}</td>
                            <td class="text-center">
                                {% if tache.terminee %}
                                    <span class="badge bg-success">✅ Terminée</span>
                                {% else %}
                                    <span class="badge bg-warning text-dark">📝 En cours</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        <p class="mt-3 text-muted">
            {{ taches|length }} tâche(s) en base de données
        </p>
    {% endif %}
{% endblock %}